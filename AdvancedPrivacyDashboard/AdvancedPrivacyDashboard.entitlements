<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- No sandbox — required for system monitoring tools -->
    <key>com.apple.security.app-sandbox</key>
    <false/>

    <!-- Network access (GeoIP, HIBP API, update checker) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- File access for TCC database, exports, system logs -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>

    <!-- Login item (SMAppService) -->
    <key>com.apple.developer.service-management.login-item</key>
    <true/>

    <!-- App Group for widget data sharing -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.com.privacydashboard.shared</string>
    </array>

    <!-- Hardened runtime exceptions for system command execution -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.automation.apple-events</key>
    <true/>
</dict>
</plist>
